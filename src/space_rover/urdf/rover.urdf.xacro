<?xml version="1.0"?>
<robot name="rover" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= MATERIALS ================= -->
  <material name="light_gray">
    <color rgba="0.7 0.7 0.75 1"/>
  </material>

  <material name="accent">
    <color rgba="0.9 0.6 0.1 1"/>
  </material>

  <material name="gray">
    <color rgba="0.5 0.5 0.5 1"/>
  </material>

  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>

  <!-- ================= BASE ================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.7 0.5 0.12"/>
      </geometry>
      <material name="light_gray"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.7 0.5 0.12"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="10.0"/>
      <inertia ixx="1" iyy="1" izz="1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ================= MAST ================= -->
  <link name="mast_link">
    <visual>
      <geometry>
        <cylinder radius="0.022" length="0.16"/>
      </geometry>
      <material name="light_gray"/>
    </visual>
  </link>

  <joint name="mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="mast_link"/>
    <origin xyz="0.16 0 0.14"/>
  </joint>

  <!-- ================= CAMERA ================= -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.12 0.08 0.06"/>
      </geometry>
      <material name="accent"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.12 0.08 0.06"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="mast_link"/>
    <child link="camera_link"/>
    <origin xyz="0.18 0 0.02" rpy="0 0.14 0"/>
  </joint>

  <!-- ================= LIDAR ================= -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.18 0 0.035"/>
  </joint>

  <!-- ================= ARM ================= -->
  <link name="left_arm">
    <visual>
      <geometry>
        <box size="0.4 0.05 0.05"/>
      </geometry>
      <material name="gray"/>
    </visual>
  </link>

  <joint name="left_arm_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_arm"/>
    <origin xyz="0 0.25 -0.05"/>
  </joint>

  <!-- ================= SOLAR PANEL ================= -->
  <link name="solar_panel">
    <visual>
      <geometry>
        <box size="0.5 0.3 0.02"/>
      </geometry>
      <material name="accent"/>
    </visual>
  </link>

  <joint name="solar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="solar_panel"/>
    <origin xyz="-0.1 0 0.15"/>
  </joint>

  <!-- ================= WHEELS ================= -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}">
      <visual>
        <origin rpy="1.5707 0 0"/>
        <geometry>
          <cylinder radius="0.12" length="0.06"/>
        </geometry>
        <material name="black"/>
      </visual>

      <collision>
        <origin rpy="1.5707 0 0"/>
        <geometry>
  	<cylinder radius="0.12" length="0.06"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} -0.12"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- LEFT WHEELS -->
  <xacro:wheel name="front_left_wheel" x="0.25" y="0.25"/>
  <xacro:wheel name="mid_left_wheel" x="0" y="0.25"/>
  <xacro:wheel name="rear_left_wheel" x="-0.25" y="0.25"/>

  <!-- RIGHT WHEELS -->
  <xacro:wheel name="front_right_wheel" x="0.25" y="-0.25"/>
  <xacro:wheel name="mid_right_wheel" x="0" y="-0.25"/>
  <xacro:wheel name="rear_right_wheel" x="-0.25" y="-0.25"/>

  <!-- INCLUDE GAZEBO FILE -->
  <xacro:include filename="rover.gazebo"/>

</robot>
