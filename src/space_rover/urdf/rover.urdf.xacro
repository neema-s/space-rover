<?xml version="1.0"?>
<robot name="rover" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Base -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.6 0.4 0.15"/>
      </geometry>
    </visual>
  </link>
    <!-- Camera -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.2 0 0.15"/>
  </joint>

  <!-- LIDAR -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.2"/>
  </joint>

  <!-- Wheels -->
  <!-- Left side -->
  <link name="front_left_wheel"><visual><geometry><cylinder radius="0.08" length="0.06"/></geometry></visual></link>
  <link name="mid_left_wheel"><visual><geometry><cylinder radius="0.08" length="0.06"/></geometry></visual></link>
  <link name="rear_left_wheel"><visual><geometry><cylinder radius="0.08" length="0.06"/></geometry></visual></link>

  <!-- Right side -->
  <link name="front_right_wheel"><visual><geometry><cylinder radius="0.08" length="0.06"/></geometry></visual></link>
  <link name="mid_right_wheel"><visual><geometry><cylinder radius="0.08" length="0.06"/></geometry></visual></link>
  <link name="rear_right_wheel"><visual><geometry><cylinder radius="0.08" length="0.06"/></geometry></visual></link>

  <!-- Joints -->

  <!-- Left wheels -->
  <joint name="fl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.25 0.2 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="ml_joint" type="continuous">
    <parent link="base_link"/>
    <child link="mid_left_wheel"/>
    <origin xyz="0 0.2 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rl_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.25 0.2 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Right wheels -->
  <joint name="fr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.25 -0.2 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="mr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="mid_right_wheel"/>
    <origin xyz="0 -0.2 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rr_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.25 -0.2 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>
